# 复制为 .env 后按需修改。
# .env 不要提交到 Git。

# 数据存储：
# - json: 使用 MYUSIC_DATA_DIR\collector\*.json
# - postgres: 使用 PostgreSQL 保存下载任务和入库记录
MYUSIC_STORAGE=postgres
DATABASE_URL=postgres://myusic:your_password@127.0.0.1:5432/myusic

# 运行数据目录。音乐、cookies、Navidrome 数据和运行配置都会放在这里。
MYUSIC_DATA_DIR=D:\project\MYusic-data

# API / Web 控制台。
# 本地默认 http://127.0.0.1:8787；云端可改端口并通过反向代理暴露。
MYUSIC_API_HOST=0.0.0.0
MYUSIC_API_PORT=8787

# Navidrome。
# MYUSIC_NAVIDROME_URL 是 API 调用 Navidrome 的地址。
MYUSIC_NAVIDROME_HOST=0.0.0.0
MYUSIC_NAVIDROME_PORT=4533
MYUSIC_NAVIDROME_URL=http://127.0.0.1:4533
MYUSIC_NAVIDROME_USER=
MYUSIC_NAVIDROME_PASSWORD=
# Docker 部署时 app 容器和 Navidrome 容器看到的同一个音乐卷路径不同；
# docker-compose.yml 已默认设置为 /music，本地直跑通常不需要配置。
# MYUSIC_NAVIDROME_MUSIC_FOLDER=/music

# 是否由本运行时启动 Navidrome。
# 本地 Windows 默认 true；Docker 云端建议 false，交给独立 Navidrome 容器。
MYUSIC_MANAGED_NAVIDROME=true

# 登录鉴权。
# Postgres 模式默认启用。首次打开页面会创建管理员账号。
MYUSIC_AUTH_ENABLED=true
MYUSIC_AUTH_COOKIE=myusic_session
MYUSIC_AUTH_SESSION_DAYS=30
MYUSIC_AUTH_SECURE_COOKIE=false

# 可选：覆盖默认音乐目录。默认是 MYUSIC_DATA_DIR\library。
# MYUSIC_LIBRARY_DIR=D:\project\MYusic-data\library

# 可选：覆盖本地工具路径。默认优先使用项目 bin 目录。
# MYUSIC_YTDLP_PATH=D:\project\MYusic\bin\yt-dlp.exe
# MYUSIC_FFMPEG_PATH=D:\project\MYusic\bin\ffmpeg.exe

# 可选：B 站 cookies 文件。默认是 MYUSIC_DATA_DIR\cookies\bilibili.txt。
# MYUSIC_BILIBILI_COOKIES=D:\project\MYusic-data\cookies\bilibili.txt

# 下载行为。
MYUSIC_AUDIO_FORMAT=mp3
MYUSIC_AUDIO_QUALITY=0
MYUSIC_MAX_JOBS=50

# Music Agent (DeepSeek Chat Completions API)
MYUSIC_DEEPSEEK_API_KEY=
MYUSIC_DEEPSEEK_BASE_URL=https://api.deepseek.com
MYUSIC_AGENT_MODEL=deepseek-chat

