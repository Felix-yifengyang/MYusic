# 复制为 .env 后按需修改。
# .env 不要提交 Git。

# json: 使用 D:\project\personal-music-stack-data\collector\*.json
# postgres: 使用 PostgreSQL 保存下载任务和入库记录
PERSONAL_MUSIC_STORAGE=json

# PERSONAL_MUSIC_STORAGE=postgres 时启用。
# DATABASE_URL=postgres://personal_music:personal_music_dev@127.0.0.1:5432/personal_music

# 可选。默认是 D:\project\personal-music-stack-data
# PERSONAL_MUSIC_DATA_DIR=D:\project\personal-music-stack-data
