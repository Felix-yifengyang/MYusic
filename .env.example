# 复制为 .env 后按需修改。
# .env 不要提交到 Git。

# 数据存储：
# - json: 使用 PERSONAL_MUSIC_DATA_DIR\collector\*.json
# - postgres: 使用 PostgreSQL 保存下载任务和入库记录
PERSONAL_MUSIC_STORAGE=postgres
DATABASE_URL=postgres://MYusic:your_password@127.0.0.1:5432/MYusic

# 运行数据目录。音乐、cookies、Navidrome 数据和运行配置都会放在这里。
PERSONAL_MUSIC_DATA_DIR=D:\project\personal-music-stack-data

# API / Web 控制台。
# 本地默认 http://127.0.0.1:8787；云端可改端口并通过反向代理暴露。
PERSONAL_MUSIC_API_HOST=0.0.0.0
PERSONAL_MUSIC_API_PORT=8787

# Navidrome。
# PERSONAL_MUSIC_NAVIDROME_URL 是 API 调用 Navidrome 的地址。
PERSONAL_MUSIC_NAVIDROME_HOST=0.0.0.0
PERSONAL_MUSIC_NAVIDROME_PORT=4533
PERSONAL_MUSIC_NAVIDROME_URL=http://127.0.0.1:4533
PERSONAL_MUSIC_NAVIDROME_USER=
PERSONAL_MUSIC_NAVIDROME_PASSWORD=

# 登录鉴权。
# Postgres 模式默认启用。首次打开页面会创建管理员账号。
PERSONAL_MUSIC_AUTH_ENABLED=true
PERSONAL_MUSIC_AUTH_COOKIE=personal_music_session
PERSONAL_MUSIC_AUTH_SESSION_DAYS=30
PERSONAL_MUSIC_AUTH_SECURE_COOKIE=false

# 可选：覆盖默认音乐目录。默认是 PERSONAL_MUSIC_DATA_DIR\library。
# PERSONAL_MUSIC_LIBRARY_DIR=D:\project\personal-music-stack-data\library

# 可选：覆盖本地工具路径。默认优先使用项目 bin 目录。
# PERSONAL_MUSIC_YTDLP_PATH=D:\project\personal-music-stack\bin\yt-dlp.exe
# PERSONAL_MUSIC_FFMPEG_PATH=D:\project\personal-music-stack\bin\ffmpeg.exe

# 可选：B 站 cookies 文件。默认是 PERSONAL_MUSIC_DATA_DIR\cookies\bilibili.txt。
# PERSONAL_MUSIC_BILIBILI_COOKIES=D:\project\personal-music-stack-data\cookies\bilibili.txt

# 下载行为。
PERSONAL_MUSIC_AUDIO_FORMAT=mp3
PERSONAL_MUSIC_AUDIO_QUALITY=0
PERSONAL_MUSIC_MAX_JOBS=50
